{
  "name": "eslint-plugin-friday",
  "version": "1.0.0",
  "description": "Opinionated ESLint rules for consistent, readable TypeScript and React codebases.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "eslintconfig",
    "eslint-config",
    "typescript",
    "react",
    "jsx",
    "lint",
    "code-style"
  ],
  "homepage": "https://github.com/next-friday/eslint-plugin-friday#readme",
  "bugs": {
    "url": "https://github.com/next-friday/eslint-plugin-friday/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/next-friday/eslint-plugin-friday.git",
    "directory": "packages/eslint-plugin-friday"
  },
  "license": "MIT",
  "author": "Next Friday",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "depcruise": "depcruise --config .dependency-cruiser.mjs src",
    "doc": "eslint-doc-generator",
    "doc:check": "eslint-doc-generator --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.59",
    "emoji-regex": "^10.6.0"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.61.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10",
    "eslint-doc-generator": "^3.6.0",
    "tsdown": "^0.22",
    "typescript": "^6",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "engines": {
    "node": ">=22.10.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
