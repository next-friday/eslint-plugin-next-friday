{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "doc": {
      "dependsOn": ["build"],
      "cache": false
    },
    "doc:check": {
      "dependsOn": ["build"],
      "cache": false
    },
    "test": {
      "dependsOn": []
    },
    "test:coverage": {
      "dependsOn": [],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": []
    }
  }
}
