{
  "name": "eslint-plugin-friday",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "clean": "rm -rf .turbo coverage packages/*/dist packages/*/coverage packages/*/.turbo packages/*/*.tsbuildinfo",
    "depcruise": "pnpm --filter eslint-plugin-friday depcruise",
    "doc": "turbo run doc",
    "doc:check": "turbo run doc:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "remote-test": "eslint-remote-tester",
    "sort": "sort-package-json \"package.json\" \"packages/*/package.json\"",
    "sort:check": "sort-package-json --check \"package.json\" \"packages/*/package.json\"",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck && tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7",
    "@changesets/cli": "^2",
    "@commitlint/cli": "^21",
    "@commitlint/config-conventional": "^21",
    "@eslint/js": "^10",
    "eslint": "^10",
    "eslint-config-prettier": "^10",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "eslint-plugin-friday": "workspace:*",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^65.0.1",
    "eslint-remote-tester": "^4.0.4",
    "eslint-remote-tester-repositories": "^2.0.2",
    "husky": "^9",
    "knip": "^6",
    "lint-staged": "^17",
    "prettier": "^3",
    "sort-package-json": "^4",
    "turbo": "^2",
    "typescript": "^6",
    "typescript-eslint": "^8.59"
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=22.10.0",
    "pnpm": ">=9.0.0"
  }
}
